# Copy this file to .env on the Azure VM before running docker compose.

# Public domain and ports handled by Caddy.
APP_DOMAIN=po-integration-example.dirrini.tech
HTTP_PORT=80
HTTPS_PORT=443

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# RabbitMQ internal credentials.
# Keep defaults only for demos. Change for any real deployment.
RABBITMQ_DEFAULT_USER=projectpulse
RABBITMQ_DEFAULT_PASS=change-this-rabbitmq-password
RabbitMq__HostName=rabbitmq
RabbitMq__UserName=projectpulse
RabbitMq__Password=change-this-rabbitmq-password

# External GraphQL product integration.
# Example: https://your-project-pulse-domain.com/graphql
EXTERNAL_PRODUCTS_GRAPHQL_URL=https://replace-with-your-graphql-host/graphql
EXTERNAL_PRODUCTS_API_KEY=replace-with-your-integration-api-key
ExternalProducts__GraphqlUrl=https://replace-with-your-graphql-host/graphql
ExternalProducts__ApiKey=replace-with-your-integration-api-key
